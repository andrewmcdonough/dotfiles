{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(yarn:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(bundle:*)",
      "Bash(ruby:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(dc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(tee:*)",
      "Bash(dotenv:*)",
      "Bash(bin/:*)",
      "Bash(./bin/:*)",
      "Bash(yamllint:*)",
      "Bash(source:*)",
      "Bash(for:*)",
      "WebSearch",
      "WebFetch",
      "mcp__playwright__*",
      "mcp__rollbar__*",
      "mcp__trello__*"
    ],
    "deny": [
      "Bash(op *)",
      "Bash(chsc:*)",
      "Bash(ch-staging-console:*)",
      "Bash(chsbc:*)",
      "Bash(ch-sandbox-console:*)",
      "Bash(chpc:*)",
      "Bash(ch-production-console:*)",
      "Bash(chscw:*)",
      "Bash(ch-staging-write-console:*)",
      "Bash(chpcw:*)",
      "Bash(ch-production-write-console:*)",
      "Bash(scribe-console:*)",
      "Bash(*scribe-console*)",
      "Bash(gh workflow run:*)",
      "Bash(gh workflow run *)"
    ],
    "ask": [
      "Bash(*rails db:*)",
      "Bash(psql*)",
      "Bash(sqlite3*)",
      "Bash(redis-cli*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); current_dir=$(echo \"$input\" | jq -r '.workspace.current_dir'); model=$(echo \"$input\" | jq -r '.model.display_name'); printf \"\\033[2m%s@%s:%s\\033[0m \\033[36m[%s]\\033[0m\" \"$(whoami)\" \"$(hostname -s)\" \"$(basename \"$current_dir\")\" \"$model\""
  },
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "serena@claude-plugins-official": true
  }
}
